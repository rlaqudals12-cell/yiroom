# EAS Build: monorepo root .easignore
# .easignore overrides default behavior, so must include node_modules etc.

# Node modules (root and web - mobile's is needed for build)
node_modules/
!apps/mobile/node_modules/
!packages/shared/node_modules/

# Git
.git/

# Web app: keep package.json for workspace resolution, exclude everything else
# (웹 소스는 모바일 빌드에 불필요 + (main)/[id] 경로가 Linux tar 추출 실패 유발)
apps/web/*
!apps/web/package.json

# Vercel build output (심링크 포함 → Linux tar 추출 실패, 2026-07-04 빌드 실패 원인)
.vercel/

# Documentation with Korean filenames (causes tar extraction errors on Linux)
docs/

# IDE
.vscode/
.idea/

# Test artifacts
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# Mobile build artifacts (regenerated)
apps/mobile/dist/
apps/mobile/android/
apps/mobile/ios/

# Other
*.log
.beads/
.claude/
.husky/
.turbo/
stitch_total_wellness_ai_homepage/
