# EAS Build: monorepo root .easignore
# .easignore overrides default behavior, so must include node_modules etc.

# Node modules (root and web - mobile's is needed for build)
node_modules/
!apps/mobile/node_modules/
!packages/shared/node_modules/
apps/web/node_modules/

# Git
.git/

# Web app (not needed for mobile build)
apps/web/.next/
apps/web/dist/
apps/web/coverage/
apps/web/tests/

# Documentation with Korean filenames (causes tar extraction errors on Linux)
docs/

# IDE
.vscode/
.idea/

# Test artifacts
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# Mobile build artifacts (regenerated)
apps/mobile/dist/
apps/mobile/android/
apps/mobile/ios/

# Other
*.log
.claude/
.husky/
.turbo/
